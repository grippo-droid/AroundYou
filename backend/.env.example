MONGO_URI=mongodb://localhost:27017
DB_NAME=around_you_db
JWT_SECRET=CHANGE_THIS_TO_A_SUPER_SECRET_KEY_IN_PRODUCTION
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
COOKIE_NAME=access_token
COOKIE_SECURE=False
DOMAIN=localhost
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:8080","http://localhost:5173"]

# ── SMS / OTP ──────────────────────────────────────────────────────────────────
# "console" prints OTP to server log (dev). Set to "msg91" or "twilio" in prod.
SMS_PROVIDER=console

# MSG91 (India) — create account at https://msg91.com, register DLT template
MSG91_API_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=NRME

# Twilio — create account at https://twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Cloudinary (image uploads) ─────────────────────────────────────────────
# Create a free account at https://cloudinary.com — Dashboard shows all three values
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
