# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB connection string from MongoDB Atlas (or local for dev)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Name of the database to use
DB_NAME=around_you_db

# ── Auth ──────────────────────────────────────────────────────────────────────
# Long random secret used to sign JWT tokens — generate with: openssl rand -hex 32
JWT_SECRET=your-long-random-secret-here

# Secret key required when registering an admin account via /auth/register-admin
ADMIN_SECRET_KEY=aroundyou-admin-secret

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slashes)
# http://localhost:5173 and http://localhost:8080 are always included automatically
ALLOWED_ORIGINS=https://your-app.vercel.app

# ── SMS / OTP ──────────────────────────────────────────────────────────────────
# "console" prints OTP to server logs (dev/staging)
# "msg91"   uses MSG91 (recommended for India)
# "twilio"  uses Twilio
SMS_PROVIDER=console

# MSG91 credentials — only needed when SMS_PROVIDER=msg91
MSG91_API_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=NRME

# Twilio credentials — only needed when SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Cloudinary (image uploads) ─────────────────────────────────────────────────
# Required to enable business image uploads via /uploads/image
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
